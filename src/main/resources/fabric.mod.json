{
  "schemaVersion": 1,
  "id": "skinshuffle",
  "version": "${mod_version}",
  "name": "SkinShuffle",
  "description": "Choose and change your skin in-game!",
  "authors": [
    "IMB11 (mineblock11)",
    "enjarai"
  ],
  "contributors": [
    "cassiancc"
  ],
  "contact": {
    "repo": "https://github.com/IMB11-Mods/SkinShuffle",
    "issues": "https://github.com/IMB11-Mods/SkinShuffle/issues"
  },
  "license": "MIT",
  "icon": "assets/skinshuffle/icon.png",
  "accessWidener": "skinshuffle.classtweaker",
  "environment": "*",
  "entrypoints": {
    "yumi:client_init": [
      "dev.imb11.skinshuffle.client.SkinShuffleClient"
    ],
    "yumi:init": [
      "dev.imb11.skinshuffle.SkinShuffle"
    ],
    "modmenu": [
      "dev.imb11.skinshuffle.compat.ModMenuCompat"
    ]
  },
  "mixins": [
    "SkinShuffle.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${target_fabricloader}",
    "fabric-api": "*",
    "yet_another_config_lib_v3": "${target_yacl}",
    "minecraft": "${target_minecraft}"
  },
  "suggests": {
    "capes": "*"
  }
}
